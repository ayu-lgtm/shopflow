{
  "info": {
    "name": "ShopFlow v2 — JWT Auth (Complete Test Suite)",
    "description": "Complete JWT auth test suite for User + Admin roles. \n\n**Setup:** Set baseUrl variable to http://localhost:8080\n\n**Flow:**\n1. Run 'Admin Login' → auto-saves token\n2. Run 'User Register' → auto-saves user token\n3. Test all endpoints",
    "_postman_id": "shopflow-jwt-v2",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",    "value": "http://localhost:8080", "type": "string" },
    { "key": "adminToken", "value": "",                      "type": "string" },
    { "key": "userToken",  "value": "",                      "type": "string" }
  ],
  "item": [
    {
      "name": "1. Auth — Public",
      "item": [
        {
          "name": "Admin Login ✅",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has token', () => pm.expect(pm.response.json().token).to.be.a('string'));",
                  "pm.test('Role is ADMIN', () => pm.expect(pm.response.json().role).to.eql('ADMIN'));",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('adminToken', json.token);",
                  "console.log('Admin token saved:', json.token.substring(0,30) + '...');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@shopflow.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/users/login", "host": ["{{baseUrl}}"], "path": ["api","users","login"] }
          }
        },
        {
          "name": "User Register ✅",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Has token', () => pm.expect(pm.response.json().token).to.be.a('string'));",
                  "pm.test('Role is USER', () => pm.expect(pm.response.json().role).to.eql('USER'));",
                  "pm.collectionVariables.set('userToken', pm.response.json().token);",
                  "console.log('User token saved');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"testuser@shopflow.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/users/register", "host": ["{{baseUrl}}"], "path": ["api","users","register"] }
          }
        },
        {
          "name": "User Login ✅",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has token', () => pm.expect(pm.response.json().token).to.be.a('string'));",
                  "pm.collectionVariables.set('userToken', pm.response.json().token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@shopflow.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/users/login", "host": ["{{baseUrl}}"], "path": ["api","users","login"] }
          }
        },
        {
          "name": "Login — Wrong Password ❌ (expect 400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400 for wrong password', () => pm.response.to.have.status(400));",
                  "pm.test('Error message present', () => pm.expect(pm.response.json().error).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@shopflow.com\",\n  \"password\": \"wrongpassword\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/users/login", "host": ["{{baseUrl}}"], "path": ["api","users","login"] }
          }
        },
        {
          "name": "Login — User Not Found ❌ (expect 400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400 for unknown user', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"nobody@example.com\",\n  \"password\": \"pass\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/users/login", "host": ["{{baseUrl}}"], "path": ["api","users","login"] }
          }
        },
        {
          "name": "Register — Duplicate Email ❌ (expect 400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400 for duplicate email', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Duplicate\",\n  \"email\": \"admin@shopflow.com\",\n  \"password\": \"somepass\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/users/register", "host": ["{{baseUrl}}"], "path": ["api","users","register"] }
          }
        }
      ]
    },
    {
      "name": "2. Users — Protected",
      "item": [
        {
          "name": "GET /api/users/all — Admin ✅",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns array', () => pm.expect(pm.response.json()).to.be.an('array'));",
                  "pm.test('Contains admin user', () => {",
                  "  const users = pm.response.json();",
                  "  const adminUser = users.find(u => u.email === 'admin@shopflow.com');",
                  "  pm.expect(adminUser).to.not.be.undefined;",
                  "  pm.expect(adminUser.role).to.eql('ADMIN');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/users/all", "host": ["{{baseUrl}}"], "path": ["api","users","all"] }
          }
        },
        {
          "name": "GET /api/users/all — User Token ❌ (expect 403)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 403 for non-admin', () => pm.response.to.have.status(403));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/users/all", "host": ["{{baseUrl}}"], "path": ["api","users","all"] }
          }
        },
        {
          "name": "GET /api/users/all — No Token ❌ (expect 401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401 for no token', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/users/all", "host": ["{{baseUrl}}"], "path": ["api","users","all"] }
          }
        },
        {
          "name": "GET /api/users/profile — Admin ✅",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns admin email', () => pm.expect(pm.response.json().email).to.eql('admin@shopflow.com'));",
                  "pm.test('Role is ADMIN', () => pm.expect(pm.response.json().role).to.eql('ADMIN'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/users/profile", "host": ["{{baseUrl}}"], "path": ["api","users","profile"] }
          }
        },
        {
          "name": "GET /api/users/profile — User ✅",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Role is USER', () => pm.expect(pm.response.json().role).to.eql('USER'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/users/profile", "host": ["{{baseUrl}}"], "path": ["api","users","profile"] }
          }
        },
        {
          "name": "GET /api/users/profile — No Token ❌ (expect 401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
