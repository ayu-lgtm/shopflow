        },
        {
          "name": "GET /api/products/health — Public ✅",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Status UP', () => pm.expect(pm.response.json().status).to.eql('UP'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/products/health", "host": ["{{baseUrl}}"], "path": ["api","products","health"] }
          }
        }
      ]
