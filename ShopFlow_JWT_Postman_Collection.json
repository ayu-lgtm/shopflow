                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns array', () => pm.expect(pm.response.json()).to.be.an('array'));",
                  "if (pm.response.json().length > 0) {",
                  "  pm.collectionVariables.set('productId', pm.response.json()[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/products", "host": ["{{baseUrl}}"], "path": ["api","products"] }
          }
        },
        {
          "name": "GET /api/products/search — Public ✅",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/products/search?name=laptop",
              "host": ["{{baseUrl}}"],
              "path": ["api","products","search"],
              "query": [{ "key": "name", "value": "laptop" }]
