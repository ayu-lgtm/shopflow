            "url": { "raw": "{{baseUrl}}/api/users/profile", "host": ["{{baseUrl}}"], "path": ["api","users","profile"] }
          }
        },
        {
          "name": "GET /api/users/validate — Public ✅",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns exists=true for admin', () => pm.expect(pm.response.json().exists).to.be.true);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/users/validate?email=admin@shopflow.com",
              "host": ["{{baseUrl}}"],
              "path": ["api","users","validate"],
              "query": [{ "key": "email", "value": "admin@shopflow.com" }]
            }
          }
        }
      ]
