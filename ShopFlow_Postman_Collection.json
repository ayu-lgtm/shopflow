{
  "info": {
    "name": "ShopFlow API Collection",
    "description": "Complete API tests for ShopFlow microservices. \n\nSetup:\n1. Pehle Register ya Login karo\n2. Token automatically {{authToken}} variable mein save ho jaayega\n3. Phir baaki requests chalao",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string",
      "description": "API Gateway URL"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string",
      "description": "JWT Token - auto-set after login/register"
    }
  ],
  "item": [
    {
      "name": "1. Health Checks",
      "item": [
        {
          "name": "User Service Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/users/health",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "health"]
            }
          }
        },
        {
          "name": "Product Service Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/products/health",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products", "health"]
            }
          }
        }
      ]
    },
    {
      "name": "2. User Auth",
      "item": [
        {
          "name": "Register User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.token) {",
                  "    pm.collectionVariables.set('authToken', res.token);",
                  "    console.log('Token saved:', res.token);",
                  "    pm.test('Registration successful', () => pm.response.to.have.status(200));",
                  "    pm.test('Token present', () => pm.expect(res.token).to.be.a('string'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ayush Test\",\n  \"email\": \"ayush@shopflow.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "register"]
            }
          }
        },
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.token) {",
                  "    pm.collectionVariables.set('authToken', res.token);",
                  "    console.log('Token saved:', res.token);",
                  "    pm.test('Login successful', () => pm.response.to.have.status(200));",
                  "    pm.test('Token received', () => pm.expect(res.token).to.be.a('string'));",
                  "    pm.test('Role present', () => pm.expect(res.role).to.be.a('string'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ayush@shopflow.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "login"]
            }
          }
        },
        {
          "name": "Get All Users (Auth Required)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/all",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "all"]
            }
          }
        },
        {
          "name": "Validate User Email",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/users/validate?email=ayush@shopflow.com",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "validate"],
              "query": [
                { "key": "email", "value": "ayush@shopflow.com" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "3. Products",
      "item": [
        {
          "name": "Get All Products (Public)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/products",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products"]
            }
          }
        },
        {
          "name": "Get Product by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/products/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products", "1"]
            }
          }
        },
        {
          "name": "Search Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/products/search?name=phone",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products", "search"],
              "query": [
                { "key": "name", "value": "phone" }
              ]
            }
          }
        },
        {
          "name": "Create Product (Auth Required)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "var res = pm.response.json();",
                  "if (res.id) pm.collectionVariables.set('lastProductId', res.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Samsung Galaxy S24\",\n  \"description\": \"Latest Android flagship phone\",\n  \"price\": 74999.00,\n  \"category\": \"Electronics\",\n  \"stock\": 50\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/products",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products"]
            }
          }
        },
        {
          "name": "Delete Product (Auth Required)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/products/{{lastProductId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products", "{{lastProductId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "4. Auth Error Tests",
      "item": [
        {
          "name": "Access Protected Route - No Token (should 401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Should return 401 Unauthorized', () => pm.response.to.have.status(401));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/users/all",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "all"]
            }
          }
        },
        {
          "name": "Login with Wrong Password (should 500/400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Should fail login', () => pm.expect(pm.response.code).to.be.oneOf([400, 500]));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ayush@shopflow.com\",\n  \"password\": \"wrongpassword\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "login"]
            }
          }
        },
        {
          "name": "Register Duplicate Email (should fail)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Should reject duplicate email', () => pm.expect(pm.response.code).to.be.oneOf([400, 500]));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Duplicate User\",\n  \"email\": \"ayush@shopflow.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "register"]
            }
          }
        }
      ]
    }
  ]
}
